{
  "task": {
    "name": "engineering_estimation"
  },
  "agent": {
    "max_tool_iterations": 10,
    "max_attempt_iterations": 60,
    "latency": {
      "thread_join_timeout_seconds": 1.0,
      "new_task_user_input_timeout_seconds": 60.0,
      "in_progress_wait_command_timeout_seconds": 5.0,
      "hint_input_timeout_seconds": 60.0,
      "agent_message_poll_timeout_seconds": 0.1,
      "user_progress_notice_interval_seconds": 8.0,
      "agent_user_message_wait_timeout_seconds": 2.0
    }
  },
  "llm": {
    "enable_provider_fallback": true,
    "priority_chain": ["deepseek", "claude", "openai"],
    "context_trimming": {
    },
    "retry": {
      "max_attempts": 5,
      "base": 0.5,
      "max_delay": 60.0
    },
    "provider_settings": {
      "claude": {
        "model": "claude-3-5-sonnet-latest",
        "base_url": "https://api.anthropic.com",
        "timeout": 120.0,
        "max_tokens": 1024,
        "anthropic_version": "2023-06-01",
        "context_window": 200000
      },
      "deepseek": {
        "model": "deepseek-chat",
        "base_url": "https://api.deepseek.com/v1",
        "timeout": 120.0,
        "context_window": 64000
      },
      "openai": {
        "model": "gpt-4o",
        "base_url": "https://api.openai.com/v1",
        "timeout": 120.0,
        "context_window": 128000
      },
      "minmax": {
        "model": "MiniMax-Text-01",
        "base_url": "https://api.minimax.chat/v1",
        "timeout": 120.0,
        "context_window": 1000000
      },
      "glm": {
        "model": "glm-4",
        "base_url": "https://open.bigmodel.cn/api/paas/v4",
        "timeout": 120.0,
        "context_window": 128000
      },
      "kimi": {
        "model": "moonshot-v1-8k",
        "base_url": "https://api.moonshot.cn/v1",
        "timeout": 120.0,
        "context_window": 128000
      }
    }
  },
  "context_truncation": {
    "react": {
      "tool_arg_max_chars": 300,
      "tool_result_max_chars": 500,
      "summary_provider": "deepseek",
      "keep_first_units": 1,
      "keep_last_units": 3,
      "summary_ratio": 0.20
    }
  },
  "storage": {
    "backend": "file",
    "file": {
      "path": "tests/runtime/agent_documents.json"
    },
    "sqlite": {
      "allowed_databases": {
        "material_price": "tests/runtime/material_price.db"
      },
      "path": "tests/runtime/material_price.db"
    },
    "chromadb": {
      "persist_directory": "",
      "allowed_collections": ["agent_documents"],
      "collection_name": "agent_documents"
    },
    "mysql": {
      "host": "",
      "port": 3306,
      "allowed_databases": [],
      "database": "",
      "charset": "utf8mb4"
    }
  },
  "tools": {
    "package": null,
    "modules": [],
    "retry": {
      "max_attempts": 4,
      "backoff_seconds": [1.0, 2.0, 4.0]
    }
  },
  "tracing": {
    "enabled": true,
    "output_path": "var/tracing/traces.jsonl",
    "payload_redaction_enabled": false,
    "max_content_length": 2048
  },
  "log": {
    "dir": "var/logs"
  },
  "time": {
    "timezone": "shanghai"
  },
  "token_budget": {
    "react": {
      "reserve_ratio": 0.20,
      "role_ratios": {
        "system":    0.1,
        "user":      0.1,
        "assistant": 0.4,
        "tool":      0.4
      }
    }
  }
}
